# 复制为 .env 并填入真实值，勿将 .env 提交到版本库
# cp .env.example .env

# ----- 数据库（对应 database.json 中 connection.password_env） -----
DB_PASSWORD=

# ----- LLM API Key（对应 models.json 中各模型的 api_key_env） -----
OPENAI_API_KEY=
QWEN_API_KEY=
DEEPSEEK_API_KEY=

# ----- 可选：HuggingFace 镜像（初始化 embedding 时若无法访问 huggingface.co 可设置） -----
# HF_ENDPOINT=https://hf-mirror.com

# ----- 可选：自定义配置目录（默认使用 config/json/） -----
# APP_CONFIG_DIR=/path/to/your/config