{
  "intent_divide": {
    "model_name": "qwen3-max",
    "max_retry_attempts": 3,
    "max_tool_rounds": 4,
    "column_query_top_k": 10
  },
  "sql_generation": {
    "pipeline": {
      "model_name": "qwen3-max",
      "max_concurrency": 3,
      "max_rows": 100,
      "max_rounds_per_intent": 4
    },
    "intent_runtime": {
      "model_name": "qwen3-max",
      "max_runtime_iterations": 12,
      "max_no_progress_rounds": 3,
      "max_repeated_error_class": 2,
      "timeout_ms_per_call": 30000,
      "agent_max_retries": 3
    },
    "autolink": {
      "model_name": "qwen3-max",
      "max_rounds": 8,
      "max_meta_tables": 8,
      "max_explorer_steps": 2
    }
  },
  "initialize": {
    "agent": {
      "model_name": "qwen3-max"
    },
    "embedding": {
      "model_name": "BAAI/bge-small-zh-v1.5",
      "model_path_name": "bge-small-zh-v1.5",
      "normalize_embeddings": true,
      "batch_size": 32,
      "device": "",
